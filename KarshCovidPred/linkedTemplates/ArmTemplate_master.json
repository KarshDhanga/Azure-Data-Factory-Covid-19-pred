{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "KarshCovidPred"
		},
		"ls_ablob_covidstoragesaa_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_ablob_covidstoragesaa'"
		},
		"ls_adl_covidreportinsaa_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adl_covidreportinsaa'"
		},
		"ls_adl_covidreportinsaa_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://covidreportinsaa.dfs.core.windows.net/"
		},
		"tr_ingest_population_data_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/63d0c01d-0b02-4017-b677-64a88283e1b3/resourceGroups/training/providers/Microsoft.Storage/storageAccounts/covidstoragesaa"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "KarshCovidPred_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_ablob_covidstoragesaa_connectionString": {
						"value": "[parameters('ls_ablob_covidstoragesaa_connectionString')]"
					},
					"ls_adl_covidreportinsaa_accountKey": {
						"value": "[parameters('ls_adl_covidreportinsaa_accountKey')]"
					},
					"ls_adl_covidreportinsaa_properties_typeProperties_url": {
						"value": "[parameters('ls_adl_covidreportinsaa_properties_typeProperties_url')]"
					},
					"tr_ingest_population_data_properties_typeProperties_scope": {
						"value": "[parameters('tr_ingest_population_data_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}